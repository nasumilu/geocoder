{
    "name": "nasumilu/geocoder",
    "description": "Geocoder for php.",
    "license": "Apache-2.0",
    "authors": [
        {
            "name": "Michael Lucas",
            "email": "mlucas@nasumilu.com"
        }
    ],
    "require": {
        "php": ">=7.4",
        "nasumilu/geometry": "dev-main",
        "symfony/options-resolver": "v5.3.0",
        "symfony/http-client": "v5.3.3"
    },
    "require-dev": {
        "phpunit/phpunit": "9.5.6"
    },
    "autoload": {
        "psr-4": {
            "Nasumilu\\Spatial\\Geocoder\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Nasumilu\\Spatial\\Geocoder\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable" : true
    
}
